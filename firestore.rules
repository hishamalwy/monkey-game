rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function isRoomHost(roomData) {
      return isAuth() && roomData.hostUid == request.auth.uid;
    }

    function isRoomPlayer(roomData) {
      return isAuth() && roomData.players != null && roomData.players[request.auth.uid] != null;
    }

    // ── User Profiles ──────────────────────────────────────────
    // Any authenticated user can read profiles (leaderboard, avatars)
    // Only the owner can create or update their own profile
    // Wins/losses/gamesPlayed can only increase (prevent stat manipulation)
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId)
        && request.resource.data.uid == userId;
      allow update: if isOwner(userId)
        && (!resource.data.keys().hasAll(['wins']) || request.resource.data.wins >= resource.data.wins)
        && (!resource.data.keys().hasAll(['gamesPlayed']) || request.resource.data.gamesPlayed >= resource.data.gamesPlayed)
        && (!resource.data.keys().hasAll(['xp']) || request.resource.data.xp >= resource.data.xp)
        && request.resource.data.uid == resource.data.uid;
    }

    // ── Username Reservations ──────────────────────────────────
    // Anyone authenticated can check if a name exists
    // Creating/deleting is allowed (client enforces ownership via transactions)
    match /usernames/{name} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow delete: if isAuth();
      allow update: if false;
    }

    // ── Game Rooms ─────────────────────────────────────────────
    // Any authenticated user can read rooms (browsing, reconnecting)
    // Only authenticated users can create rooms (hostUid must match auth)
    // Updates: must be a player in the room OR the host
    // Deletes: only the host can delete a room
    match /rooms/{roomCode} {
      allow read: if isAuth();

      allow create: if isAuth()
        && request.resource.data.hostUid == request.auth.uid;

      allow update: if isAuth()
        && (isRoomPlayer(resource.data) || isRoomHost(resource.data))
        && request.resource.data.hostUid == resource.data.hostUid;

      allow delete: if isAuth()
        && isRoomHost(resource.data);
    }

    // ── Match History (subcollection) ──────────────────────────
    // Users can only write to their own match history
    // Records are append-only (create only, no update/delete)
    match /users/{userId}/matches/{matchId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if false;
      allow delete: if false;
    }

    // ── Reports ───────────────────────────────────────────────
    // Any authenticated user can create a report
    // No one can read, update, or delete reports (admin-only via console)
    match /reports/{reportId} {
      allow create: if isAuth()
        && request.resource.data.reporterUid == request.auth.uid;
      allow read: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ── Purchases ─────────────────────────────────────────────
    match /purchases/{purchaseId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if false;
      allow delete: if false;
    }
  }
}
